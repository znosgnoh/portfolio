# Database (Vercel Postgres / Neon)
# DATABASE_URL is the pooled connection (used at runtime)
# DIRECT_URL is the direct connection (used for migrations)
DATABASE_URL="postgresql://user:password@localhost:5432/nosgnoh_life?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/nosgnoh_life?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Admin credentials (used for seeding)
ADMIN_EMAIL="nosgnohz@gmail.com"
ADMIN_PASSWORD="change-me-in-production"

# Google Drive API (Service Account)
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_DRIVE_FOLDER_ID=""

# Google Analytics
NEXT_PUBLIC_GA_ID=""
