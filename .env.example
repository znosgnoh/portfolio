# Database (Neon via Vercel Marketplace — or local Postgres for offline work)
# DATABASE_URL = pooled connection (runtime / Prisma adapter)
# DIRECT_URL   = unpooled / direct (prisma db push, migrations)
# After linking Neon: `vercel env pull .env.local` then map:
#   DATABASE_URL        <- pooled (often DATABASE_URL)
#   DIRECT_URL          <- DATABASE_URL_UNPOOLED or DIRECT_URL from Neon
DATABASE_URL="postgresql://nosgnoh@localhost:5432/nosgnoh_life?schema=public"
DIRECT_URL="postgresql://nosgnoh@localhost:5432/nosgnoh_life?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Admin credentials (used for seeding)
ADMIN_EMAIL="nosgnohz@gmail.com"
ADMIN_PASSWORD="change-me-in-production"

# Google Drive API (Service Account)
# Root folder should be Nosgnoh.life/ — album subfolders are discovered under it
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_DRIVE_FOLDER_ID=""

# Google Analytics
NEXT_PUBLIC_GA_ID=""
